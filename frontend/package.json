{
  "name": "clearrun-records",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "react-scripts": "5.0.1",
    "axios": "^1.7.7",
    "lucide-react": "^0.446.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.2",
    "class-variance-authority": "^0.7.0"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "test": "craco test",
    "serve:build": "node scripts/serve-build.mjs",
    "serve:review": "node scripts/serve-build.mjs",
    "visual:screenshots": "playwright test --config=playwright.config.js tests/visual-review.spec.js",
    "review:visual": "playwright test --config=playwright.config.js",
    "lighthouse:review": "node scripts/run-lighthouse.mjs",
    "review:lighthouse": "node scripts/run-lighthouse.mjs",
    "visual:summary": "node scripts/summarize-visual-review.mjs",
    "review:frontend": "npm run build && npm run visual:screenshots && npm run lighthouse:review && npm run visual:summary",
    "review": "npm run build && npm run review:visual && npm run review:lighthouse"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@craco/craco": "^7.1.0",
    "@playwright/test": "1.61.1",
    "autoprefixer": "^10.4.20",
    "chrome-launcher": "1.1.2",
    "lighthouse": "13.4.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "ts-node": "10.9.2"
  }
}
